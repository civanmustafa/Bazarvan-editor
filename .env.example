VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key
EDITOR_PUBLIC_URL=https://editor.example.com

# Server-only keys stay out of browser builds.
# Keep Gemini/OpenAI keys in server runtime variables when production API routes are added.
GEMINI_API_KEYS=
GEMINI_PAID_API_KEYS=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_PAID_MODEL=gemini-2.5-pro
GEMINI_ALLOWED_MODELS=
OPENAI_API_KEY=
OPENAI_API_KEYS=
# 32 random bytes encoded as Base64. Used only to encrypt administrator AI keys in Supabase.
AI_SETTINGS_ENCRYPTION_KEY=
FIRECRAWL_API_KEY=
COMPETITOR_PREVIEW_CACHE_HOURS=24
N8N_INGEST_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=

# Durable content-writing worker. One concurrent session avoids overlapping long article generations.
CONTENT_WRITING_WORKER_POLL_MS=1500
CONTENT_WRITING_SESSION_LEASE_SECONDS=1800
CONTENT_WRITING_WORKER_CONCURRENCY=1
