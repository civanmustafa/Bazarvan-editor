{
  "name": "smart-editor-v9.9-يتعدل",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run check:secrets",
    "build": "vite build && node scripts/build-server.mjs",
    "build:web": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "preview": "vite preview",
    "start": "node server-dist/server.mjs",
    "start:worker": "node server-dist/external-analysis-worker.mjs",
    "start:ai-jobs": "node server-dist/ai-job-worker.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:security && npm run test:performance && npm run test:architecture",
    "test:security": "node --experimental-strip-types --test tests/apiSecurity.test.ts tests/articleAccessAndSave.test.ts tests/settingsRegistry.test.ts tests/aiExecutionEngine.test.ts tests/aiJobService.test.ts",
    "test:performance": "node --experimental-strip-types --test tests/performanceArchitecture.test.ts",
    "test:architecture": "node --experimental-strip-types --test tests/codeArchitecture.test.ts",
    "check:bundle": "node scripts/check-web-performance.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "check:dependencies": "npm audit --audit-level=moderate",
    "verify": "npm run check:secrets && npm run check:dependencies && npm run typecheck && npm run test && npm run build && npm run check:bundle",
    "verify:security": "npm run check:secrets && npm run test:security",
    "verify:performance": "npm run test:performance && npm run build:web && npm run check:bundle",
    "verify:architecture": "npm run test:architecture && npm run build"
  },
  "dependencies": {
    "@fontsource/cairo": "^5.2.7",
    "@google/genai": "^1.52.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tiptap/core": "^3.7.2",
    "@tiptap/extension-highlight": "^3.7.2",
    "@tiptap/extension-table": "^3.7.2",
    "@tiptap/extension-table-cell": "^3.7.2",
    "@tiptap/extension-table-header": "^3.7.2",
    "@tiptap/extension-table-row": "^3.7.2",
    "@tiptap/extension-text-align": "^3.7.2",
    "@tiptap/react": "^3.7.2",
    "@tiptap/starter-kit": "^3.7.2",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "lucide-react": "^0.546.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "use-context-selector": "^2.0.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.4.3"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "protobufjs": "7.6.5",
    "ws": "8.21.0"
  }
}
