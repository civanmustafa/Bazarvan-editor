NODE_ENV=production
PORT=8080
EDITOR_PUBLIC_URL=https://editor.example.com

# Public Supabase values used while building the browser app.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-publishable-or-anon-key

# Private server-only AI keys. Never put these in VITE_* variables.
GEMINI_API_KEYS=gemini-key-1,gemini-key-2
OPENAI_API_KEY=your-openai-api-key

# Private n8n ingest values.
N8N_INGEST_TOKEN=make-a-long-random-secret-token
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Durable external-analysis worker. Failed jobs are retried after 30 minutes.
EXTERNAL_ANALYSIS_WORKER_POLL_MS=5000
EXTERNAL_ANALYSIS_JOB_LEASE_SECONDS=300
EXTERNAL_ANALYSIS_RETRY_MINUTES=30
EXTERNAL_ANALYSIS_WORKER_CONCURRENCY=5
